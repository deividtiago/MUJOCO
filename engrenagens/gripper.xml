<mujoco>
    <compiler meshdir="meshes"/>
    <default>
        <mesh scale="0.001 0.001 0.001" />

        <default class="passive">
            <geom rgba="1 0 1 1" mass="0" />
        </default>
        <default class="active">
            <geom rgba="1 0 1 1" mass="0" />
        </default>
    </default>
    <asset>
        <!--Engrenagens-->
        <!--passive_gear-->
        <mesh name="passive_gear" file="engrenagens/passiva/passive_gear.stl"/>
        
        <!--Collisions meshes passive gear-->
        <mesh name="collision_passive_gear" file="engrenagens/passiva/collisions/collision_passive_gear.stl" />
        <mesh name="collision_passive_gear_t1" file="engrenagens/passiva/collisions/collision_passive_gear_t1.stl" />
        <mesh name="collision_passive_gear_t2"  file="engrenagens/passiva/collisions/collision_passive_gear_t2.stl" />
        <mesh name="collision_passive_gear_t3" file="engrenagens/passiva/collisions/collision_passive_gear_t3.stl" />
        <mesh name="collision_passive_gear_t4" file="engrenagens/passiva/collisions/collision_passive_gear_t4.stl" />
        <mesh name="collision_passive_gear_t5" file="engrenagens/passiva/collisions/collision_passive_gear_t5.stl" />
        <mesh name="collision_passive_gear_t6" file="engrenagens/passiva/collisions/collision_passive_gear_t6.stl" />
        <mesh name="collision_passive_gear_t7" file="engrenagens/passiva/collisions/collision_passive_gear_t7.stl" />
        <mesh name="collision_passive_gear_t8" file="engrenagens/passiva/collisions/collision_passive_gear_t8.stl" />
        <mesh name="collision_passive_gear_t9" file="engrenagens/passiva/collisions/collision_passive_gear_t9.stl" />
        <mesh name="collision_passive_gear_t10" file="engrenagens/passiva/collisions/collision_passive_gear_t10.stl" />
        <mesh name="collision_passive_gear_t11" file="engrenagens/passiva/collisions/collision_passive_gear_t11.stl" />
        <mesh name="collision_passive_gear_t12" file="engrenagens/passiva/collisions/collision_passive_gear_t12.stl" />
        
        <!--active_gear-->
        <mesh name="active_gear"  file="engrenagens/ativa/active_gear.stl" />

                <!--Collisions meshes active gear-->
        <mesh name="collision_active_gear" file="engrenagens/ativa/collisions/collision_active_gear.stl" />
        <mesh name="collision_active_gear_t1" file="engrenagens/ativa/collisions/collision_active_gear_t1.stl" />
        <mesh name="collision_active_gear_t2" file="engrenagens/ativa/collisions/collision_active_gear_t2.stl" />
        <mesh name="collision_active_gear_t3" file="engrenagens/ativa/collisions/collision_active_gear_t3.stl" />
        <mesh name="collision_active_gear_t4" file="engrenagens/ativa/collisions/collision_active_gear_t4.stl" />
        <mesh name="collision_active_gear_t5" file="engrenagens/ativa/collisions/collision_active_gear_t5.stl" />
        <mesh name="collision_active_gear_t6" file="engrenagens/ativa/collisions/collision_active_gear_t6.stl" />
        <mesh name="collision_active_gear_t7" file="engrenagens/ativa/collisions/collision_active_gear_t7.stl" />
        <mesh name="collision_active_gear_t8" file="engrenagens/ativa/collisions/collision_active_gear_t8.stl" />
        <mesh name="collision_active_gear_t9" file="engrenagens/ativa/collisions/collision_active_gear_t9.stl" />
        <mesh name="collision_active_gear_t10" file="engrenagens/ativa/collisions/collision_active_gear_t10.stl" />
        <mesh name="collision_active_gear_t11" file="engrenagens/ativa/collisions/collision_active_gear_t11.stl" />
        
        <mesh name="active_pivot" file="engrenagens/ativa/active_pivot.stl" />
    </asset>

    
    <worldbody>
        <!--Plano-->
        <body>
            <geom type="plane" size="1 1 0.0001" />
        </body>

        <!--Gripper-->
        <body name="gripper" >
            <body name="active_gear_body">
                <!--adiciona a engrenagem ativa conectada ao servo-->
                <geom type="mesh" class="active" mass="0.1" mesh="active_gear" contype="1" conaffinity="1" />

                <joint name="active_gear_joint" type="hinge"  pos="0 0 0" axis="0 0 1" damping="0.01" range="-40 40" />
  
                <geom type="mesh" class="active" mass="0" mesh="collision_active_gear" />
                <geom type="mesh" class="active" mass="0" mesh="collision_active_gear_t1" />
                <geom type="mesh" class="active" mass="0" mesh="collision_active_gear_t2" />
                <geom type="mesh" class="active" mass="0" mesh="collision_active_gear_t3" />
                <geom type="mesh" class="active" mass="0" mesh="collision_active_gear_t4" />
                <geom type="mesh" class="active" mass="0" mesh="collision_active_gear_t5" />
                <geom type="mesh" class="active" mass="0" mesh="collision_active_gear_t6" />
                <geom type="mesh" class="active" mass="0" mesh="collision_active_gear_t7" />
                <geom type="mesh" class="active" mass="0" mesh="collision_active_gear_t8" />
                <geom type="mesh" class="active" mass="0" mesh="collision_active_gear_t9" />
                <geom type="mesh" class="active" mass="0" mesh="collision_active_gear_t10" />
                <geom type="mesh" class="active" mass="0" mesh="collision_active_gear_t11" />

            </body>
            <!--Adiciona a engrenagem passiva-->
            <body>
                <geom type="mesh" class="passive" mass="0.1" mesh="passive_gear" contype="1" conaffinity="1" />
                
                <geom type="mesh" class="passive" mass="0" mesh="collision_passive_gear" />
                <geom type="mesh" class="passive" mass="0" mesh="collision_passive_gear_t1" />
                <geom type="mesh" class="passive" mass="0" mesh="collision_passive_gear_t2" />
                <geom type="mesh" class="passive" mass="0" mesh="collision_passive_gear_t3" />
                <geom type="mesh" class="passive" mass="0" mesh="collision_passive_gear_t4" />
                <geom type="mesh" class="passive" mass="0" mesh="collision_passive_gear_t5" />
                <geom type="mesh" class="passive" mass="0" mesh="collision_passive_gear_t6" />
                <geom type="mesh" class="passive" mass="0" mesh="collision_passive_gear_t7" />
                <geom type="mesh" class="passive" mass="0" mesh="collision_passive_gear_t8" />
                <geom type="mesh" class="passive" mass="0" mesh="collision_passive_gear_t9" />
                <geom type="mesh" class="passive" mass="0" mesh="collision_passive_gear_t10" />
                <geom type="mesh" class="passive" mass="0" mesh="collision_passive_gear_t11" />
                <geom type="mesh" class="passive" mass="0" mesh="collision_passive_gear_t12" />

                <joint type="hinge" name="passive_gear_joint" pos="0.027999 0 0" damping="0.01" />
            </body>
        </body>

    </worldbody>
</mujoco>